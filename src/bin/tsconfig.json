{
    "compilerOptions": {
        "sourceMap": false,
        "newLine": "LF",
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "composite": true,
        "rootDir": "./",
        "module": "ES2020",
        "target": "ES2017",
        "esModuleInterop": true,
        "lib": ["es2015", "ES2019.Object"],
        "moduleResolution": "bundler"
    },
    "include": ["./**/*.ts"],
    "exclude": ["./initialize-account-theme/boilerplate"],
    "ts-node": {
        "esm": true
    }
}
